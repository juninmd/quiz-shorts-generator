# OpenRouter (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001

# Workflow selection and local paths
WORKFLOW_ID=quiz
OUTPUT_DIR=output
WORKSPACE_ROOT=temp_assets/jobs

# Telegram (optional - shorts are distributed via Telegram when configured)
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# YouTube (optional - videos are uploaded to YouTube when configured)
ENABLE_YOUTUBE=false
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CLIENT_ID=your_oauth2_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth2_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_oauth2_refresh_token_here
YOUTUBE_CHANNEL_NAME=your_channel_name_here

# youtube-clips workflow
# Comma-separated list of channel handles or URLs
YOUTUBE_CLIP_CHANNELS=@channelA,@channelB,https://www.youtube.com/@channelC
# Max clips to generate per video (default: 2)
YOUTUBE_CLIPS_MAX=2
# Remote Whisper service URL (required for youtube-clips)
WHISPER_BASE_URL=http://localhost:9000
# Optional: YouTube cookies in base64 (for age-restricted/bot-protected videos)
YOUTUBE_COOKIES_BASE64=
# Optional: path to cookies.txt file
YOUTUBE_COOKIES_FILE=
