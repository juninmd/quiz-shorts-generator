# Ollama (required - defaults to localhost if not set)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# Telegram (optional - shorts are distributed via Telegram when configured)
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# YouTube (optional - videos are uploaded to YouTube when configured)
YOUTUBE_CLIENT_ID=your_oauth2_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth2_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_oauth2_refresh_token_here
YOUTUBE_CHANNEL_NAME=your_channel_name_here
